# Salt service base URL (auth provider callback at /auth/provider/callback)
# Testnet: https://salt.testnet.mysocial.network
# Production: https://salt.mysocial.network
NEXT_PUBLIC_API_BASE_URL=https://salt.testnet.mysocial.network

# Auth home footer: which expected app host to show (mainnet | testnet).
# testnet → auth.testnet.mysocial.network; mainnet → do.my-social.network
NEXT_PUBLIC_MYSOCIAL_NETWORK=testnet

# Optional: Override auth callback path if backend uses different route (default: /auth/provider/callback)
# NEXT_PUBLIC_AUTH_CALLBACK_PATH=/api/auth/provider/callback

# Optional: Override wallet auth callback path (default: /auth/wallet/callback)
# NEXT_PUBLIC_AUTH_WALLET_CALLBACK_PATH=/auth/wallet/callback

# Required: 32+ character secret for encrypting auth state cookies
# Generate with: openssl rand -base64 32
AUTH_STATE_SECRET=your-32-character-minimum-secret-here

# Optional default callback host for server-side helpers (login always uses `redirect_uri` from the URL).
# NEXT_PUBLIC_AUTH_CALLBACK_URL=https://auth.testnet.mysocial.network/callback

# OAuth provider client IDs (from each provider's developer console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_CLIENT_ID=
NEXT_PUBLIC_FACEBOOK_APP_ID=
NEXT_PUBLIC_TWITCH_CLIENT_ID=

# Optional: JSON allowlist for client_id and redirect_uri validation
# Format: [{"clientId":"...","redirectUris":["https://..."]}]
# ALLOWED_CLIENTS=

# Direct access: when users land on the auth frontend without URL params,
# these enable the login/wallet UI. client_id must match backend allowlist.
# code_challenge: generate with PKCE (e.g. echo -n "verifier-43-chars-min" | openssl dgst -binary -sha256 | base64 | tr '+/' '-_' | tr -d '=')
# NEXT_PUBLIC_DEV_CLIENT_ID=
# NEXT_PUBLIC_DEV_CODE_CHALLENGE=
# NEXT_PUBLIC_DEV_REDIRECT_URI=  # optional, defaults to {origin}/callback

# Where to redirect after Create/Import wallet (e.g. main app URL)
# NEXT_PUBLIC_APP_REDIRECT_URI=
